{
  "manifest_version": 3,
  "name": "Simple Notes",
  "version": "1.0.0",
  "description": "A lightweight notes extension with auto-save and search.",
  "action": {
    "default_title": "Simple Notes",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon100.png"
  }
}
